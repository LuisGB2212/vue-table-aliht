{
  "name": "@devkit/vue-transactions-table",
  "version": "1.0.0",
  "description": "A reusable Vue 3 transactions table component with Pinia store, filtering, pagination, and status management",
  "type": "module",
  "main": "./dist/vue-transactions-table.umd.cjs",
  "module": "./dist/vue-transactions-table.js",
  "exports": {
    ".": {
      "import": "./dist/vue-transactions-table.js",
      "require": "./dist/vue-transactions-table.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "build:lib": "vite build --mode lib"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "pinia": "^2.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.13",
    "pinia": "^2.1.7"
  },
  "keywords": [
    "vue",
    "vue3",
    "pinia",
    "transactions",
    "table",
    "component",
    "tailwindcss"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/vue-transactions-table"
  }
}
