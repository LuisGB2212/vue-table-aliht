{
  "name": "vue-data-table-corporative",
  "version": "1.0.0",
  "description": "A reusable Vue 3 data table component with Pinia store, filtering, pagination, and status management",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vue-data-table-corporative.umd.cjs",
  "module": "./dist/vue-data-table-corporative.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-data-table-corporative.js",
      "require": "./dist/vue-data-table-corporative.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "concurrently \"tailwindcss -i src/style.dev.css -o src/tailwind.generated.css --watch\" \"vite\"",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "build:lib": "vite build --mode lib"
  },
  "peerDependencies": {
    "pinia": "^2.1.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.0",
    "pinia": "^2.1.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.13"
  },
  "keywords": [
    "vue",
    "vue3",
    "pinia",
    "transactions",
    "table",
    "component",
    "tailwindcss"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuisGB2212/vue-table-aliht"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  }
}
